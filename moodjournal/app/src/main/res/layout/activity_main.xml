<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/greetingText"
                    android:text="Good Morning ☀️"
                    android:textSize="15sp"
                    android:textColor="#8B7E9F"
                    android:fontFamily="sans-serif-medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="Mood Journal"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="#2D2A3A"
                    android:letterSpacing="-0.02"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Avatar/Profile circle -->
            <androidx.cardview.widget.CardView
                android:layout_width="52dp"
                android:layout_height="52dp"
                app:cardCornerRadius="26dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">
                <TextView
                    android:text="🌸"
                    android:textSize="24sp"
                    android:layout_gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Hero card: How are you feeling? -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@android:color/transparent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_hero_card"
                android:padding="22dp">

                <TextView
                    android:text="How are you feeling today?"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="Tap a mood to log it instantly"
                    android:textSize="13sp"
                    android:textColor="#F1E8FF"
                    android:layout_marginTop="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <!-- Mood emoji quick picker -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="20dp"
                    android:weightSum="5">

                    <TextView
                        android:id="@+id/moodHappy"
                        android:text="😄"
                        android:textSize="28sp"
                        android:gravity="center"
                        android:padding="10dp"
                        android:background="@drawable/bg_mood_chip"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:id="@+id/moodCalm"
                        android:text="😌"
                        android:textSize="28sp"
                        android:gravity="center"
                        android:padding="10dp"
                        android:background="@drawable/bg_mood_chip"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:id="@+id/moodMeh"
                        android:text="😐"
                        android:textSize="28sp"
                        android:gravity="center"
                        android:padding="10dp"
                        android:background="@drawable/bg_mood_chip"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:id="@+id/moodSad"
                        android:text="😢"
                        android:textSize="28sp"
                        android:gravity="center"
                        android:padding="10dp"
                        android:background="@drawable/bg_mood_chip"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:id="@+id/moodAngry"
                        android:text="😡"
                        android:textSize="28sp"
                        android:gravity="center"
                        android:padding="10dp"
                        android:background="@drawable/bg_mood_chip"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Stats row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="18dp"
            android:weightSum="2">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="18dp"
                android:background="@drawable/bg_stat_card_pink"
                android:layout_marginEnd="8dp">

                <TextView
                    android:text="🔥 Streak"
                    android:textSize="13sp"
                    android:textColor="#8B5A6B"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/streakText"
                    android:text="0 days"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#3B2A35"
                    android:layout_marginTop="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="18dp"
                android:background="@drawable/bg_stat_card_mint"
                android:layout_marginStart="8dp">

                <TextView
                    android:text="🌿 Entries"
                    android:textSize="13sp"
                    android:textColor="#3F6B5A"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/entryCountText"
                    android:text="0"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#1F3B30"
                    android:layout_marginTop="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Action Buttons -->
        <Button
            android:id="@+id/addMood"
            android:text="＋  Add Mood Entry"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_btn_primary"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="22dp"/>

        <Button
            android:id="@+id/viewHistory"
            android:text="📖  View History"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:textColor="#5B4B7A"
            android:background="@drawable/bg_btn_secondary"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"/>

        <Button
            android:id="@+id/viewGraph"
            android:text="📊  View Mood Graph"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:textColor="#5B4B7A"
            android:background="@drawable/bg_btn_secondary"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"/>

        <!-- Today's tip card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_tip_card"
            android:gravity="center_vertical">

            <TextView
                android:text="💡"
                android:textSize="28sp"
                android:layout_marginEnd="14dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:text="Tip of the day"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#6B5A2A"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="Take 3 deep breaths before logging your mood."
                    android:textSize="13sp"
                    android:textColor="#7A6A3A"
                    android:layout_marginTop="2dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
