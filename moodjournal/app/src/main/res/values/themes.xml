<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.MoodJournal" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="CustomCalendarHeader" parent="TextAppearance.AppCompat.Medium">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="CustomCalendarWeek" parent="TextAppearance.AppCompat.Small">
        <item name="android:textColor">#E1BEE7</item>
    </style>

    <style name="CustomCalendarDate" parent="TextAppearance.AppCompat.Small">
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="WhiteCalendarTheme">
        <item name="colorControlNormal">#FFFFFF</item>
    </style>
</resources>